@page "/bmi"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]

<PageTitle>Калькулятор ИМТ</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-5">
                    <h2 class="text-center fw-bold text-primary mb-4">Калькулятор ИМТ</h2>

                    <div class="mb-3">
                        <label class="form-label text-muted">Ваш рост (см)</label>
                        <input type="number" class="form-control form-control-lg" @bind="height" placeholder="Напр: 175" />
                    </div>

                    <div class="mb-4">
                        <label class="form-label text-muted">Ваш вес (кг)</label>
                        <input type="number" class="form-control form-control-lg" @bind="weight" placeholder="Напр: 70" />
                    </div>

                    <button class="btn btn-primary btn-lg w-100 rounded-pill mb-4" @onclick="Calculate">Рассчитать</button>

                    @if (bmi > 0)
                    {
                        <div class="text-center p-3 rounded-3 @resultClass">
                            <h4 class="mb-1">Ваш ИМТ: @bmi.ToString("F1")</h4>
                            <p class="mb-0 fw-bold">@resultMessage</p>
                        </div>

                        <div class="mt-4 small text-muted">
                            <p>
                                <strong>Справка:</strong><br>
                                &lt; 18.5: Дефицит массы<br>
                                18.5—24.9: Норма<br>
                                25—29.9: Избыточный вес<br>
                                &gt; 30: Ожирение
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private double height;
    private double weight;
    private double bmi;
    private string resultMessage = "";
    private string resultClass = "";

    private void Calculate()
    {
        if (height > 0 && weight > 0)
        {
            double heightInMeters = height / 100;
            bmi = weight / (heightInMeters * heightInMeters);

            if (bmi < 18.5) { resultMessage = "Дефицит массы тела"; resultClass = "bg-info text-white"; }
            else if (bmi < 25) { resultMessage = "Нормальный вес"; resultClass = "bg-success text-white"; }
            else if (bmi < 30) { resultMessage = "Избыточный вес"; resultClass = "bg-warning text-dark"; }
            else { resultMessage = "Ожирение"; resultClass = "bg-danger text-white"; }
        }
    }
}